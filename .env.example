# ── Required in production (Railway) ─────────────────────────────────────────

# Django backend service URL.
# Used at BUILD TIME to configure the Nitro server-side proxy for /api/* and /media/*.
# Set this in your Railway frontend service env vars before deploying.
# Example: https://danlara-backend.railway.app
BACKEND_URL=https://your-backend.railway.app

# Stripe publishable key (used on the register/billing page).
# Get this from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_

# Leave empty — the Nitro server proxies /api/* and /media/* to BACKEND_URL.
# Only set if you want the browser to call the backend directly (requires CORS on Django).
VITE_API_URL=
